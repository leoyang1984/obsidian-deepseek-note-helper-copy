{
    "compilerOptions": {
        "baseUrl": ".",
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ESNext",
        "allowJs": true,
        "noImplicitAny": true,
        "moduleResolution": "node",
        "importHelpers": true,
        "lib": [
            "DOM",
            "ESNext"
        ],
        "skipLibCheck": true,
        "strict": true,
        "verbatimModuleSyntax": true
    },
    "include": [
        "src/**/*.ts"
    ]
}